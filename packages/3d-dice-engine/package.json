{
  "name": "@lambersond/3d-dice-engine",
  "version": "0.3.0",
  "description": "Vendored fork of @3d-dice/dice-box-threejs: a three.js + cannon-es 3D dice engine. Consumed behind @lambersond/3d-dice-core's DiceRenderer.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./public/*": "./public/*"
  },
  "bin": {
    "3d-dice-engine": "./bin/copy-assets.mjs"
  },
  "files": [
    "bin",
    "dist",
    "types",
    "public"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "cannon-es": "^0.20.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/three": "^0.184.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

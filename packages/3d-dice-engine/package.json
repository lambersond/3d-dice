{
  "name": "@lambersond/3d-dice-engine",
  "version": "0.1.0",
  "description": "Vendored fork of @3d-dice/dice-box-threejs — a three.js + cannon-es 3D dice engine. Consumed behind @lambersond/3d-dice-core's DiceRenderer.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./public/*": "./public/*"
  },
  "bin": {
    "3d-dice-engine": "./bin/copy-assets.mjs"
  },
  "files": [
    "bin",
    "src",
    "types",
    "public"
  ],
  "dependencies": {
    "cannon-es": "^0.20.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/three": "^0.184.0"
  },
  "publishConfig": {
    "access": "public"
  }
}

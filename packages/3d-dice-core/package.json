{
  "name": "@lambersond/3d-dice-core",
  "version": "0.4.0",
  "description": "Framework-agnostic 3D dice rolling engine, parser, and renderer.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@lambersond/3d-dice-engine": "^0.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
